  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FFF3F9;
    font-family: &quot;Segoe UI&quot;;
    color: #2F2A2E;
}

QFrame#topBar {
    background: #F4D8E3;
    border: none;
}

QLabel#logoIcon {
    color: #A64B80;
    font-size: 22px;
    font-weight: 700;
    background: transparent;
}

QLabel#logoText {
    color: #9B4B78;
    font-size: 21px;
    font-weight: 800;
    background: transparent;
}

QLabel#logoSub {
    color: #A78595;
    font-size: 11px;
    font-weight: 500;
    background: transparent;
}

QPushButton#navHome {
    background: #E7BDD0;
    border: none;
    border-radius: 20px;
    color: #1E1B20;
    font-size: 16px;
    font-weight: 700;
    padding-left: 14px;
    padding-right: 14px;
}

QPushButton#navHome:hover {
    background: #E1B3C8;
}

QPushButton#navStats,
QPushButton#navChat,
QPushButton#navPublic {
    background: transparent;
    border: none;
    color: #1E1B20;
    font-size: 16px;
    font-weight: 700;
    text-align: center;
}

QPushButton#navStats:hover,
QPushButton#navChat:hover,
QPushButton#navPublic:hover {
    color: #9B4B78;
}

QLabel#topBell,
QLabel#topSetting,
QLabel#topUser {
    background: transparent;
    color: #4A3D49;
    font-size: 22px;
    font-weight: 700;
}

QPushButton#backBtn {
    background: transparent;
    border: none;
    color: #1E1B20;
    font-size: 18px;
    font-weight: 700;
    text-align: left;
}

QFrame#mainCard, QFrame#donateCard {
    background: #FFF3F9;
    border: 4px solid #EDB4CB;
    border-radius: 24px;
}

QLabel#campaignTitle {
    color: #764872;
    font-size: 24px;
    font-weight: 900;
    background: transparent;
}

QLabel#campaignDesc {
    color: #1E1B20;
    font-size: 16px;
    font-weight: 500;
    background: transparent;
}

QLabel#amountLabel, QLabel#percentLabel {
    color: #764872;
    font-size: 22px;
    font-weight: 900;
    background: transparent;
}

QFrame#progressBg {
    background: #E8D2DD;
    border: none;
    border-radius: 18px;
}

QFrame#progressFill {
    background: #E39BC8;
    border: none;
    border-radius: 18px;
}

QFrame#lineUnderProgress, QFrame#verticalLine {
    background: #EDB4CB;
    border: none;
}

QLabel#activitiesTitle,
QLabel#scopeTitle,
QLabel#dateTitle,
QLabel#ownerTitle {
    color: #1E1B20;
    font-size: 18px;
    font-weight: 900;
    background: transparent;
}

QLabel#activitiesText,
QLabel#scopeText,
QLabel#dateText,
QLabel#idLabel,
QLabel#genderLabel,
QLabel#nameLabel,
QLabel#phoneLabel,
QLabel#cccdLabel,
QLabel#addressLabel,
QLabel#emailLabel,
QLabel#idValue,
QLabel#genderValue,
QLabel#nameValue,
QLabel#phoneValue,
QLabel#cccdValue,
QLabel#addressValue,
QLabel#emailValue {
    color: #1E1B20;
    font-size: 15px;
    font-weight: 500;
    background: transparent;
}

QLabel#avatarLabel {
    background: #F2F2F2;
    border: none;
    border-radius: 8px;
}

QLabel#donateTitle {
    color: #764872;
    font-size: 24px;
    font-weight: 900;
    background: transparent;
}

QLabel#maGiaoDichLabel {
    color: #1E1B20;
    font-size: 16px;
    font-weight: 500;
    background: transparent;
}

QLineEdit#codeEdit {
    background: #FFFFFF;
    border: 2px solid #A78397;
    border-radius: 22px;
    padding-left: 18px;
    padding-right: 18px;
    color: #5B5660;
    font-size: 16px;
}

QPushButton#sendBtn {
    background: #E39BC8;
    border: none;
    border-radius: 15px;
    color: #7A456B;
    font-size: 16px;
    font-weight: 800;
}

QPushButton#sendBtn:hover {
    background: #D98CBD;
}

QLabel#qrLabel {
    background: #FFFFFF;
    border: none;
    border-radius: 8px;
}</string>
