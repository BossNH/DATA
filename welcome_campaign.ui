   <string notr="true">QMainWindow, QWidget#centralwidget {
    background: #ECECEC;
    font-family: &quot;Segoe UI&quot;;
}

QFrame#mainPanel {
    background: #FDF3F9;
    border: none;
}

QFrame#navBar {
    background: #F7D8E3;
    border: none;
}

QLabel#appTitle {
    color: #B9B9B9;
    font-size: 18px;
    font-weight: 500;
    background: transparent;
}

QLabel#brandLabel {
    color: #A14F7D;
    font-size: 18px;
    font-weight: 800;
    background: transparent;
}

QPushButton.navBtn {
    border: none;
    background: transparent;
    color: #242424;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 16px;
    text-align: center;
}

QPushButton.navBtn:hover {
    background: rgba(255,255,255,0.35);
}

QPushButton#campaignBtn {
    background: #E9B8CB;
    color: #2B2B2B;
}

QLabel#heroTitle {
    color: #6E3F63;
    font-size: 58px;
    font-weight: 900;
    background: transparent;
}

QLabel.heroText {
    color: #222222;
    font-size: 18px;
    font-weight: 400;
    background: transparent;
}

QPushButton#createBtn {
    background: #E9B8CB;
    color: #6A3E63;
    font-size: 26px;
    font-weight: 800;
    border: 1px solid #6D5061;
    border-radius: 28px;
    padding: 12px 24px;
}

QPushButton#createBtn:hover {
    background: #E4AFC5;
}

QLabel#profileIcon {
    color: #222222;
    font-size: 18px;
    background: transparent;
}

QLabel#notifIcon, QLabel#gearIcon {
    color: #232323;
    font-size: 17px;
    background: transparent;
}

QLabel#groupLabel {
    color: #B08A9E;
    font-size: 9px;
    font-weight: 600;
    background: transparent;
}</string>
