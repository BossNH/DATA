  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FFF3F9;
    font-family: &quot;Segoe UI&quot;;
    color: #2F2A2E;
}

QFrame#topBar {
    background: #F5DCE6;
    border: none;
    border-radius: 18px;
}

QLabel#logoIcon {
    color: #9C4F74;
    font-size: 24px;
    font-weight: 700;
    background: transparent;
}

QLabel#logoText {
    color: #9C4F74;
    font-size: 24px;
    font-weight: 800;
    background: transparent;
}

QLabel#logoSub {
    color: #9D8A93;
    font-size: 11px;
    font-weight: 500;
    background: transparent;
}

QPushButton#navHome,
QPushButton#navStats,
QPushButton#navChat,
QPushButton#navPublic {
    background: transparent;
    border: none;
    border-radius: 18px;
    padding: 10px 18px;
    color: #2C2328;
    font-size: 11pt;
    font-weight: 600;
    text-align: center;
}

QPushButton#navHome:hover,
QPushButton#navStats:hover,
QPushButton#navChat:hover,
QPushButton#navPublic:hover {
    background: #EEC9D8;
}

QPushButton#navHome:pressed,
QPushButton#navStats:pressed,
QPushButton#navChat:pressed,
QPushButton#navPublic:pressed {
    background: #E2B5C7;
}

QPushButton#navChat {
    background: #C98AA5;
    color: white;
    font-weight: 700;
}

QLabel#topBell,
QLabel#topSetting,
QLabel#topUser {
    background: transparent;
    color: #2C2328;
    font-size: 16pt;
    font-weight: 700;
}

QPushButton#backBtn {
    background: transparent;
    border: none;
    color: #1E1B20;
    font-size: 18px;
    font-weight: 700;
    text-align: left;
}

QFrame#mainCard {
    background: #FFF3F9;
    border: 4px solid #EDB4CB;
    border-radius: 26px;
}

QLabel#campaignTitle {
    color: #764872;
    font-size: 28px;
    font-weight: 900;
    background: transparent;
}

QLabel#campaignDesc {
    color: #1E1B20;
    font-size: 18px;
    font-weight: 500;
    background: transparent;
}

QLabel#amountLabel {
    color: #764872;
    font-size: 26px;
    font-weight: 900;
    background: transparent;
}

QLabel#percentLabel {
    color: #764872;
    font-size: 26px;
    font-weight: 900;
    background: transparent;
}

QFrame#progressBg {
    background: #E8D2DD;
    border: none;
    border-radius: 0px;
}

QFrame#progressFill {
    background: #D493C1;
    border: none;
    border-radius: 0px;
}

QFrame#lineUnderProgress {
    background: #EDB4CB;
    border: none;
}

QFrame#verticalLine {
    background: #EDB4CB;
    border: none;
}

QLabel#activitiesTitle,
QLabel#scopeTitle,
QLabel#dateTitle,
QLabel#ownerTitle {
    color: #1E1B20;
    font-size: 24px;
    font-weight: 900;
    background: transparent;
}

QLabel#activitiesText,
QLabel#scopeText,
QLabel#dateText,
QLabel#idLabel,
QLabel#genderLabel,
QLabel#nameLabel,
QLabel#phoneLabel,
QLabel#cccdLabel,
QLabel#addressLabel,
QLabel#emailLabel,
QLabel#idValue,
QLabel#genderValue,
QLabel#nameValue,
QLabel#phoneValue,
QLabel#cccdValue,
QLabel#addressValue,
QLabel#emailValue {
    color: #1E1B20;
    font-size: 17px;
    font-weight: 500;
    background: transparent;
}

QLabel#avatarLabel {
    background: #F2F2F2;
    border: none;
    border-radius: 8px;
}

QFrame#donateCard {
    background: #FFF3F9;
    border: 4px solid #EDB4CB;
    border-radius: 26px;
}

QLabel#donateTitle {
    color: #764872;
    font-size: 28px;
    font-weight: 900;
    background: transparent;
}

QLabel#qrLabel {
    background: #FFFFFF;
    border: none;
    border-radius: 10px;
}

QLabel#codeLabel {
    color: #1E1B20;
    font-size: 17px;
    font-weight: 500;
    background: transparent;
}

QLineEdit#codeEdit {
    background: #FFFFFF;
    border: 2px solid #A78397;
    border-radius: 20px;
    padding-left: 16px;
    padding-right: 16px;
    color: #5B5660;
    font-size: 15px;
}

QPushButton#sendBtn {
    background: #E39BC8;
    border: none;
    border-radius: 15px;
    color: #7A456B;
    font-size: 16px;
    font-weight: 800;
}

QPushButton#sendBtn:hover {
    background: #D98CBD;
}</string>
