  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FFF3F9;
    font-family: &quot;Segoe UI&quot;;
    color: #2F2A2E;
}

QFrame#navFrame {
    background: #F5DCE6;
    border: none;
    border-radius: 18px;
}

QLabel#logoImage {
    background: transparent;
    border: none;
}

QLabel#brandTitle {
    color: #9C4F74;
    font-size: 18pt;
    font-weight: 800;
    background: transparent;
}

QLabel#brandSubtitle {
    color: #9D8A93;
    font-size: 8pt;
    font-weight: 500;
    background: transparent;
}

QPushButton#btnHome,
QPushButton#btnCreate,
QPushButton#btnFollow,
QPushButton#btnPublic {
    background: transparent;
    border: none;
    border-radius: 18px;
    padding: 10px 18px;
    color: #2C2328;
    font-size: 11pt;
    font-weight: 600;
    text-align: center;
}

QPushButton#btnHome:hover,
QPushButton#btnCreate:hover,
QPushButton#btnFollow:hover,
QPushButton#btnPublic:hover {
    background: #EEC9D8;
}

QPushButton#btnHome:pressed,
QPushButton#btnCreate:pressed,
QPushButton#btnFollow:pressed,
QPushButton#btnPublic:pressed {
    background: #E2B5C7;
}

QPushButton#btnHome {
    background: #C98AA5;
    color: white;
    font-weight: 700;
}

QToolButton#btnNotify,
QToolButton#btnSetting,
QToolButton#btnProfile {
    background: transparent;
    border: none;
    border-radius: 18px;
    color: #2C2328;
    font-size: 16pt;
    padding: 6px;
}

QToolButton#btnNotify:hover,
QToolButton#btnSetting:hover,
QToolButton#btnProfile:hover {
    background: #EEC9D8;
}

QLabel#notifyBadge {
    background: #E74C3C;
    color: white;
    border-radius: 8px;
    font-size: 8pt;
    font-weight: 700;
    padding: 0px;
}

QFrame#campaignCard, QFrame#verifyCard {
    background: #F9EFF3;
    border: 2px solid #F0B8CD;
    border-radius: 24px;
}

QFrame#lineTop, QFrame#lineBottom, QFrame#lineVertical {
    background: #F0B8CD;
    border: none;
}

QLabel#titleLabel {
    color: #6A3C64;
    font-size: 26px;
    font-weight: 800;
}

QLabel#descLabel {
    color: #2F2A2E;
    font-size: 13px;
}

QLabel#amountLabel, QLabel#percentLabel {
    color: #6A4568;
    font-size: 22px;
    font-weight: 800;
}

QLabel#sectionTitle, QLabel#ownerTitle {
    color: #442C3E;
    font-size: 16px;
    font-weight: 700;
}

QLabel#backLabel {
    color: #1F1B1D;
    font-size: 14px;
    font-weight: 600;
}

QProgressBar {
    background: #F3DDE8;
    border: none;
    border-radius: 14px;
    text-align: center;
    min-height: 24px;
    max-height: 24px;
}

QProgressBar::chunk {
    background: #E9A4CF;
    border-radius: 14px;
}

QLabel#avatarLabel {
    background: #E7EEF6;
    border: none;
}

QLabel#verifyTitle {
    color: #7A3E6A;
    font-size: 28px;
    font-weight: 800;
    background: transparent;
}

QLabel#verifyIcon {
    font-size: 40px;
    background: transparent;
}

QLabel#verifyText {
    color: #2F2A2E;
    font-size: 18px;
    font-weight: 600;
    background: transparent;
}</string>
