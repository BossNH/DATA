  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FCEEF4;
    font-family: &quot;Segoe UI&quot;;
    color: #3B2D35;
}

QFrame#topBar {
    background: #F2D5E0;
    border: none;
    border-radius: 0px;
}

QPushButton {
    border: none;
    border-radius: 16px;
    padding: 6px 14px;
    background: transparent;
    color: #2F2A2E;
}

QPushButton#activeNavBtn {
    background: #E8B8CF;
    color: #442C3E;
    font-weight: 700;
}

QPushButton#donateBtn {
    background: #E89BC5;
    color: white;
    font-weight: 700;
    border-radius: 18px;
    min-height: 34px;
}

QPushButton#sendBtn {
    background: #E89BC5;
    color: white;
    font-weight: 700;
    border-radius: 14px;
    min-width: 70px;
    max-width: 70px;
    min-height: 30px;
}

QFrame#campaignCard, QFrame#donateCard {
    background: #F9EFF3;
    border: 2px solid #F0B8CD;
    border-radius: 24px;
}

QFrame#lineTop, QFrame#lineBottom, QFrame#lineVertical {
    background: #F0B8CD;
    border: none;
}

QLabel#titleLabel {
    color: #6A3C64;
    font-size: 26px;
    font-weight: 800;
}

QLabel#descLabel {
    color: #2F2A2E;
    font-size: 13px;
}

QLabel#amountLabel, QLabel#percentLabel {
    color: #6A4568;
    font-size: 22px;
    font-weight: 800;
}

QLabel#sectionTitle, QLabel#ownerTitle, QLabel#donateTitle {
    color: #442C3E;
    font-size: 16px;
    font-weight: 700;
}

QLabel#fieldTitle {
    color: #442C3E;
    font-size: 14px;
    font-weight: 700;
}

QLabel#fieldValue {
    color: #3F3740;
    font-size: 14px;
}

QLabel#logoText {
    color: #8B3F80;
    font-size: 24px;
    font-weight: 800;
}

QLabel#logoSubText {
    color: #9B7284;
    font-size: 11px;
}

QLabel#backLabel {
    color: #1F1B1D;
    font-size: 14px;
    font-weight: 600;
}

QLineEdit#transactionEdit {
    background: white;
    border: 1px solid #CDA8B7;
    border-radius: 18px;
    padding: 9px 14px;
    color: #4A4046;
    font-size: 13px;
}

QProgressBar {
    background: #F3DDE8;
    border: none;
    border-radius: 14px;
    text-align: center;
    min-height: 24px;
    max-height: 24px;
}

QProgressBar::chunk {
    background: #E9A4CF;
    border-radius: 14px;
}

QLabel#avatarLabel, QLabel#qrLabel {
    background: #E7EEF6;
    border: none;
}
</string>
