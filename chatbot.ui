  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FFF3F9;
    font-family: &quot;Segoe UI&quot;;
    color: #242424;
}

QWidget#centralwidget {
    background: #FFF3F9;
}

QFrame#topBar {
    background: transparent;
    border: none;
}

QFrame#navFrame {
    background: #F5DCE6;
    border: none;
    border-radius: 18px;
}

QLabel#logoImage,
QLabel#headerIcon_2,
QLabel#headerIcon,
QLabel#botIcon {
    background: transparent;
    border: none;
}

QLabel#brandTitle {
    color: #9C4F74;
    font-size: 18pt;
    font-weight: 800;
    background: transparent;
}

QLabel#brandSubtitle {
    color: #9D8A93;
    font-size: 8pt;
    font-weight: 500;
    background: transparent;
}

QPushButton#btnHome,
QPushButton#btnStats,
QPushButton#btnChatbot {
    background: transparent;
    border: none;
    border-radius: 18px;
    padding: 10px 18px;
    color: #2C2328;
    font-size: 11pt;
    font-weight: 600;
    text-align: center;
}

QPushButton#btnHome:hover,
QPushButton#btnStats:hover,
QPushButton#btnChatbot:hover {
    background: #EEC9D8;
}

QPushButton#btnHome:pressed,
QPushButton#btnStats:pressed,
QPushButton#btnChatbot:pressed {
    background: #E2B5C7;
}

QPushButton#btnChatbot {
    background: #C98AA5;
    color: white;
    font-weight: 700;
}

QToolButton#btnNotify,
QToolButton#btnSetting,
QToolButton#btnProfile {
    background: transparent;
    border: none;
    border-radius: 18px;
    color: #2C2328;
    font-size: 16pt;
    padding: 6px;
}

QToolButton#btnNotify:hover,
QToolButton#btnSetting:hover,
QToolButton#btnProfile:hover {
    background: #EEC9D8;
}

QLabel#notifyBadge {
    background: #E74C3C;
    color: white;
    border-radius: 8px;
    font-size: 8pt;
    font-weight: 700;
    padding: 0px;
}

QFrame#chatHeader {
    background: #EBC7D3;
    border: 1px solid #E2B6C4;
    border-bottom: none;
    border-top-left-radius: 22px;
    border-top-right-radius: 22px;
}

QLabel#headerTitle {
    background: transparent;
    color: #111111;
    font-size: 20px;
    font-weight: 700;
}

QLabel#headerSubtitle {
    background: transparent;
    color: #343434;
    font-size: 15px;
}

QFrame#chatPanel {
    background: transparent;
    border: 3px solid #F1B6C8;
    border-top: none;
    border-bottom-left-radius: 24px;
    border-bottom-right-radius: 24px;
}

QLabel#bubbleText {
    background: #F3D7DF;
    border: none;
    border-radius: 21px;
    color: #2C2C2C;
    font-size: 14px;
    padding-left: 18px;
}

QFrame#inputBox {
    background: #F4D6DF;
    border: none;
    border-radius: 22px;
}

QLabel#inputPlaceholder {
    background: transparent;
    color: #B3A4AC;
    font-size: 14px;
}

QPushButton#chip1,
QPushButton#chip2,
QPushButton#chip3 {
    background: #FBF5F7;
    border: 1px solid #2F2A2E;
    border-radius: 17px;
    color: #2D272B;
    font-size: 12px;
    padding-left: 14px;
    padding-right: 14px;
}

QPushButton#chip1:hover,
QPushButton#chip2:hover,
QPushButton#chip3:hover {
    background: #F7E9EE;
}

QLabel#sendArrow {
    background: transparent;
    color: #F0BFD0;
    font-size: 66px;
    font-weight: 700;
}</string>
