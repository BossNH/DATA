  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #F6EDF1;
    font-family: &quot;Segoe UI&quot;;
    color: #242424;
}

QWidget#centralwidget {
    background: #F6EDF1;
}

QFrame#topBar {
    background: #F1D7DF;
    border: none;
}

QLabel#logoText {
    color: #9A4D86;
    font-size: 22px;
    font-weight: 700;
    background: transparent;
}

QLabel#logoSubText {
    color: #8D6A7D;
    font-size: 10px;
    background: transparent;
}

QLabel#navHome,
QLabel#navStats,
QLabel#navBell,
QLabel#navSetting,
QLabel#navAvatar {
    background: transparent;
    color: #202020;
}

QFrame#chatbotTab {
    background: #DCA2C4;
    border: none;
    border-radius: 23px;
}

QLabel#navChatbot {
    background: transparent;
    color: #1F1F1F;
    font-size: 18px;
    font-weight: 700;
}

QLabel#notifBadge {
    background: #E63333;
    color: white;
    border-radius: 9px;
    font-size: 10px;
    font-weight: 700;
}

QFrame#chatHeader {
    background: #EBC7D3;
    border: 1px solid #E2B6C4;
    border-bottom: none;
    border-top-left-radius: 22px;
    border-top-right-radius: 22px;
}

QLabel#headerTitle {
    background: transparent;
    color: #111111;
    font-size: 20px;
    font-weight: 700;
}

QLabel#headerSubtitle {
    background: transparent;
    color: #343434;
    font-size: 15px;
}

QFrame#chatPanel {
    background: transparent;
    border: 3px solid #F1B6C8;
    border-top: none;
    border-bottom-left-radius: 24px;
    border-bottom-right-radius: 24px;
}

QLabel#bubbleText {
    background: #F3D7DF;
    border: none;
    border-radius: 21px;
    color: #2C2C2C;
    font-size: 14px;
    padding-left: 18px;
}

QFrame#inputBox {
    background: #F4D6DF;
    border: none;
    border-radius: 22px;
}

QLabel#inputPlaceholder {
    background: transparent;
    color: #B3A4AC;
    font-size: 14px;
}

QPushButton#chip1,
QPushButton#chip2,
QPushButton#chip3 {
    background: #FBF5F7;
    border: 1px solid #2F2A2E;
    border-radius: 17px;
    color: #2D272B;
    font-size: 12px;
    padding-left: 14px;
    padding-right: 14px;
}

QPushButton#chip1:hover,
QPushButton#chip2:hover,
QPushButton#chip3:hover {
    background: #F7E9EE;
}

QLabel#sendArrow {
    background: transparent;
    color: #F0BFD0;
    font-size: 66px;
    font-weight: 700;
}

QLabel#logoIcon,
QLabel#headerIcon,
QLabel#botIcon {
    background: transparent;
    border: none;
}</string>
