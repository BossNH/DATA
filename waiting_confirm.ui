  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #FFF3F9;
    color: #222222;
    font-family: &quot;Segoe UI&quot;;
}
QFrame#topBar {
    background-color: #F2D7E1;
    border: none;
}
QLabel#brandTitle {
    color: #7A3F73;
    font-size: 18px;
    font-weight: 800;
    background: transparent;
}
QLabel#brandSub {
    color: #8F7C88;
    font-size: 10px;
    background: transparent;
}
QPushButton.navBtn {
    background: transparent;
    border: none;
    color: #222222;
    font-size: 13px;
    font-weight: 600;
    padding: 7px 12px;
    border-radius: 18px;
    text-align: center;
}
QPushButton.navBtn:hover {
    background: rgba(255,255,255,0.35);
}
QPushButton#activeBtn {
    background-color: #E7B9CF;
    color: #1F1F1F;
    font-weight: 700;
}
QPushButton.iconBtn {
    background: transparent;
    border: none;
    color: #262626;
    font-size: 18px;
}
QLabel#notifDot {
    background-color: #E53935;
    color: white;
    border-radius: 8px;
    font-size: 10px;
    font-weight: 700;
}
QLabel#backLabel {
    color: #111111;
    font-size: 13px;
    font-weight: 600;
    background: transparent;
}
QFrame#mainCard {
    background-color: #FDFBFC;
    border: none;
    border-radius: 20px;
}
QLabel#mainTitle {
    color: #7B456F;
    font-size: 35px;
    font-weight: 800;
    background: transparent;
}
QLabel#subText1, QLabel#subText2, QLabel#bottomText {
    color: #1F1F1F;
    font-size: 16px;
    font-weight: 400;
    background: transparent;
}
QLabel#hourglassLabel {
    color: #F2C8D8;
    font-size: 150px;
    background: transparent;
}
QLabel.dotLabel {
    color: #D5CCD3;
    font-size: 30px;
    background: transparent;
}
QLabel#dotActive {
    color: #BEB3BD;
}</string>
