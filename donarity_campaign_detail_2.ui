  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">
QWidget#centralwidget{
    background:#FFF3F9;
    font-family:&quot;Segoe UI&quot;;
}

/* top */
QFrame#topBar{
    background:#F5D8E4;
    border:none;
}
QLabel#logoText{
    color:#9E4E7F;
    font-size:28px;
    font-weight:900;
}
QLabel#logoSub{
    color:#A6929D;
    font-size:10px;
    font-weight:600;
}
QPushButton#navHome,
QPushButton#navCreate,
QPushButton#navPublic{
    background:transparent;
    border:none;
    color:#2B2B2B;
    font-size:14px;
    font-weight:600;
    padding:6px 10px;
}
QPushButton#navFollow{
    background:#D5A7C1;
    border:none;
    border-radius:17px;
    color:#2B2B2B;
    font-size:14px;
    font-weight:700;
    padding:7px 16px;
}
QLabel#topIconRed{
    color:#D62C49;
    font-size:18px;
    font-weight:700;
}
QLabel#topIconDark{
    color:#1D1D1D;
    font-size:18px;
    font-weight:700;
}
QLabel#topUser{
    color:#1D1D1D;
    font-size:24px;
    font-weight:700;
}

/* back */
QPushButton#backBtn{
    background:transparent;
    border:none;
    color:#242424;
    font-size:18px;
    font-weight:700;
    text-align:left;
}

/* card */
QFrame#mainPinkCard{
    background:#F8E2EB;
    border:none;
    border-radius:24px;
}
QLabel#campaignImage{
    background:#FFFFFF;
    border:none;
    border-radius:24px;
    color:#A7A7A7;
    font-size:17px;
    font-weight:700;
}
QLabel#titleLabel{
    color:#7B4C6B;
    font-size:31px;
    font-weight:900;
}
QLabel#descLabel{
    color:#403B40;
    font-size:16px;
    font-weight:500;
}
QLabel#tagCode,
QLabel#tagCate{
    background:#F0CDDD;
    color:#B1849C;
    border-radius:11px;
    padding:4px 12px;
    font-size:12px;
    font-weight:700;
}
QLabel#tagStatus{
    background:#D9F4D8;
    color:#49A45F;
    border-radius:11px;
    padding:4px 12px;
    font-size:12px;
    font-weight:700;
}
QLabel#metaIconPink{
    color:#F1A2C5;
    font-size:17px;
    font-weight:700;
}
QLabel#metaIconPurple{
    color:#C9C7F7;
    font-size:17px;
    font-weight:700;
}
QLabel#metaText{
    color:#6C616A;
    font-size:15px;
    font-weight:500;
}

/* progress */
QFrame#progressCard{
    background:#FFFFFF;
    border:none;
    border-radius:22px;
}
QLabel#amountMain{
    color:#754C68;
    font-size:20px;
    font-weight:900;
}
QLabel#amountSub{
    color:#9E8798;
    font-size:20px;
    font-weight:800;
}
QLabel#percentLabel{
    color:#754C68;
    font-size:20px;
    font-weight:900;
}
QProgressBar#progressBar{
    border:none;
    border-radius:11px;
    background:#F5DCE7;
    min-height:24px;
    max-height:24px;
}
QProgressBar#progressBar::chunk{
    background:#EDA4CB;
    border-radius:11px;
}
QLabel#statTitle{
    color:#272727;
    font-size:17px;
    font-weight:800;
}
QLabel#statValueLeft{
    color:#AF9BAA;
    font-size:20px;
    font-weight:900;
}
QLabel#statValueRight{
    color:#A06D8F;
    font-size:20px;
    font-weight:900;
}
QLabel#miniLogo{
    color:#9E4E7F;
    font-size:18px;
    font-weight:900;
}
QLabel#miniLogoSub{
    color:#A6929D;
    font-size:10px;
    font-weight:600;
}
    </string>
   </property>
