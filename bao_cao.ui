  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FCF1F6;
    font-family: &quot;Segoe UI&quot;;
    color: #2F2A2E;
    border: none;
}

QWidget#centralwidget {
    background: #FCF1F6;
}

QLabel#logoIcon {
    background: transparent;
    color: #94406F;
    font-size: 26pt;
    font-weight: 700;
}

QLabel#logoText {
    background: transparent;
    color: #94406F;
    font-size: 18pt;
    font-weight: 800;
}

QLabel#logoSubText {
    background: transparent;
    color: #A58A98;
    font-size: 8pt;
    font-weight: 600;
}

QPushButton#backButton {
    background: transparent;
    border: none;
    color: #111111;
    font-size: 10pt;
    font-weight: 600;
    text-align: left;
    padding: 0px;
}

QPushButton#backButton:hover {
    color: #7A4A64;
}

QLabel#titleLabel {
    background: transparent;
    color: #2F2A2E;
    font-size: 25pt;
    font-weight: 800;
}

QLabel#cloud1, QLabel#cloud2, QLabel#cloud3, QLabel#cloud4 {
    background: transparent;
    color: #FBE9EF;
    border-radius: 999px;
}

QLabel#cloud1 {
    background: qradialgradient(cx:0.4, cy:0.35, radius:0.9, fx:0.35, fy:0.3,
                                stop:0 #FFFDFE, stop:0.55 #FCECF2, stop:1 #F7D5E1);
}
QLabel#cloud2 {
    background: qradialgradient(cx:0.45, cy:0.35, radius:0.95, fx:0.38, fy:0.28,
                                stop:0 #FFFDFE, stop:0.58 #FCEAF1, stop:1 #F7D2DE);
}
QLabel#cloud3 {
    background: qradialgradient(cx:0.45, cy:0.35, radius:0.95, fx:0.38, fy:0.28,
                                stop:0 #FFFDFE, stop:0.58 #FCEAF1, stop:1 #F7D2DE);
}
QLabel#cloud4 {
    background: qradialgradient(cx:0.45, cy:0.35, radius:0.95, fx:0.38, fy:0.28,
                                stop:0 #FFFDFE, stop:0.58 #FCEAF1, stop:1 #F7D2DE);
}

QLabel#spark1, QLabel#spark2, QLabel#spark3 {
    background: transparent;
    color: #F4B5C8;
    font-size: 12pt;
    font-weight: 700;
}

QLabel#dot1, QLabel#dot2, QLabel#dot3 {
    background: #FCE7EF;
    border-radius: 4px;
}</string>
