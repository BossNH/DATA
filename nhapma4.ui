  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FFF3F9;
    font-family: &quot;Segoe UI&quot;;
    color: #2F2A2E;
}

QFrame#topBar {
    background: #F4D8E3;
    border: none;
    border-radius: 0px;
}

QLabel#logoIcon {
    color: #A64B80;
    font-size: 24px;
    font-weight: 700;
    background: transparent;
}

QLabel#logoText {
    color: #9B4B78;
    font-size: 23px;
    font-weight: 800;
    background: transparent;
}

QLabel#logoSub {
    color: #A78595;
    font-size: 12px;
    font-weight: 500;
    background: transparent;
}

QPushButton#navHome {
    background: #E7BDD0;
    border: none;
    border-radius: 22px;
    color: #1E1B20;
    font-size: 18px;
    font-weight: 700;
    padding-left: 14px;
    padding-right: 14px;
}

QPushButton#navHome:hover {
    background: #E1B3C8;
}

QPushButton#navStats,
QPushButton#navChat,
QPushButton#navPublic {
    background: transparent;
    border: none;
    color: #1E1B20;
    font-size: 18px;
    font-weight: 700;
    text-align: center;
}

QPushButton#navStats:hover,
QPushButton#navChat:hover,
QPushButton#navPublic:hover {
    color: #9B4B78;
}

QLabel#topBell,
QLabel#topSetting,
QLabel#topUser {
    background: transparent;
    color: #4A3D49;
    font-size: 24px;
    font-weight: 700;
}

QPushButton#backBtn {
    background: transparent;
    border: none;
    color: #1E1B20;
    font-size: 20px;
    font-weight: 700;
    text-align: left;
}

QFrame#mainCard {
    background: #FFF3F9;
    border: 4px solid #EDB4CB;
    border-radius: 26px;
}

QLabel#campaignTitle {
    color: #764872;
    font-size: 28px;
    font-weight: 900;
    background: transparent;
}

QLabel#campaignDesc {
    color: #1E1B20;
    font-size: 18px;
    font-weight: 500;
    background: transparent;
}

QLabel#amountLabel {
    color: #764872;
    font-size: 26px;
    font-weight: 900;
    background: transparent;
}

QLabel#percentLabel {
    color: #764872;
    font-size: 26px;
    font-weight: 900;
    background: transparent;
}

QFrame#progressBg {
    background: #E8D2DD;
    border: none;
    border-radius: 0px;
}

QFrame#progressFill {
    background: #D493C1;
    border: none;
    border-radius: 0px;
}

QFrame#lineUnderProgress {
    background: #EDB4CB;
    border: none;
}

QFrame#verticalLine {
    background: #EDB4CB;
    border: none;
}

QLabel#activitiesTitle,
QLabel#scopeTitle,
QLabel#dateTitle,
QLabel#ownerTitle {
    color: #1E1B20;
    font-size: 24px;
    font-weight: 900;
    background: transparent;
}

QLabel#activitiesText,
QLabel#scopeText,
QLabel#dateText,
QLabel#idLabel,
QLabel#genderLabel,
QLabel#nameLabel,
QLabel#phoneLabel,
QLabel#cccdLabel,
QLabel#addressLabel,
QLabel#emailLabel,
QLabel#idValue,
QLabel#genderValue,
QLabel#nameValue,
QLabel#phoneValue,
QLabel#cccdValue,
QLabel#addressValue,
QLabel#emailValue {
    color: #1E1B20;
    font-size: 17px;
    font-weight: 500;
    background: transparent;
}

QLabel#avatarLabel {
    background: #F2F2F2;
    border: none;
}

QFrame#donateCard {
    background: #FFF3F9;
    border: 4px solid #EDB4CB;
    border-radius: 26px;
}

QLabel#donateTitle {
    color: #764872;
    font-size: 28px;
    font-weight: 900;
    background: transparent;
}

QLabel#successIcon {
    color: #E7A0C4;
    font-size: 62px;
    font-weight: 700;
    background: transparent;
}

QLabel#successText {
    color: #1E1B20;
    font-size: 18px;
    font-weight: 500;
    background: transparent;
}</string>
