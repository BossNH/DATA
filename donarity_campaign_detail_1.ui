  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">
QWidget#centralwidget{
    background:#FFF3F9;
    font-family:&quot;Segoe UI&quot;;
}

/* top bar */
QFrame#topBar{
    background:#F7DEE8;
    border:none;
}
QLabel#logoText{
    color:#A05582;
    font-size:28px;
    font-weight:800;
}
QLabel#logoSub{
    color:#A9919C;
    font-size:10px;
    font-weight:600;
}
QPushButton#navHome,
QPushButton#navCreate,
QPushButton#navPublic{
    background:transparent;
    border:none;
    color:#2A2A2A;
    font-size:14px;
    font-weight:600;
    padding:6px 10px;
}
QPushButton#navFollow{
    background:#D8AFC4;
    border:none;
    border-radius:16px;
    color:#2A2A2A;
    font-size:14px;
    font-weight:700;
    padding:7px 16px;
}
QLabel#topIcon{
    color:#1E1E1E;
    font-size:20px;
    font-weight:600;
}

/* back */
QPushButton#backBtn{
    background:transparent;
    border:none;
    color:#2A2A2A;
    font-size:18px;
    font-weight:700;
    text-align:left;
}

/* main pink card */
QFrame#mainPinkCard{
    background:#F9E1EB;
    border:none;
    border-radius:24px;
}
QLabel#campaignImage{
    background:#FFFFFF;
    border:none;
    border-radius:22px;
    color:#A8A8A8;
    font-size:18px;
    font-weight:700;
}
QLabel#titleLabel{
    color:#855373;
    font-size:31px;
    font-weight:900;
}
QLabel#descLabel{
    color:#403A3F;
    font-size:16px;
    font-weight:500;
}
QLabel#tagCode,
QLabel#tagCate{
    background:#F2CDDE;
    color:#B1829B;
    border-radius:11px;
    padding:4px 12px;
    font-size:12px;
    font-weight:700;
}
QLabel#tagStatus{
    background:#D7F4D9;
    color:#4FA666;
    border-radius:11px;
    padding:4px 12px;
    font-size:12px;
    font-weight:700;
}
QLabel#metaIconPink{
    color:#F2A7C8;
    font-size:17px;
    font-weight:700;
}
QLabel#metaIconPurple{
    color:#CFC6F7;
    font-size:17px;
    font-weight:700;
}
QLabel#metaText{
    color:#6B5D67;
    font-size:15px;
    font-weight:500;
}

/* progress card */
QFrame#progressCard{
    background:#FFFFFF;
    border:none;
    border-radius:22px;
}
QLabel#amountMain{
    color:#7B4B69;
    font-size:20px;
    font-weight:900;
}
QLabel#amountSub{
    color:#A38B99;
    font-size:20px;
    font-weight:800;
}
QLabel#percentLabel{
    color:#7B4B69;
    font-size:20px;
    font-weight:900;
}
QProgressBar#progressBar{
    border:none;
    border-radius:10px;
    background:#F7D8E6;
    min-height:22px;
    max-height:22px;
}
QProgressBar#progressBar::chunk{
    background:#EDA5CB;
    border-radius:10px;
}
QLabel#statTitle{
    color:#2C2C2C;
    font-size:18px;
    font-weight:800;
}
QLabel#statValueLeft{
    color:#BE9AB0;
    font-size:20px;
    font-weight:900;
}
QLabel#statValueRight{
    color:#A76E93;
    font-size:20px;
    font-weight:900;
}
QLabel#miniLogo{
    color:#A05582;
    font-size:18px;
    font-weight:900;
}
QLabel#miniLogoSub{
    color:#A9919C;
    font-size:10px;
    font-weight:600;
}
    </string>
