    <property name="styleSheet">
     <string notr="true">QScrollArea {
    border: none;
    background: #FFF6FB;
}
QScrollBar:vertical {
    background: #FBE5F0;
    width: 12px;
    margin: 0px;
    border-radius: 6px;
}
QScrollBar::handle:vertical {
    background: #E8B8D0;
    min-height: 30px;
    border-radius: 6px;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: none;
}
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}</string>
    </property>
