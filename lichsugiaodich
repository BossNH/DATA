        self.bg_label.setScaledContents(True)
        self.bg_label.lower()  # đẩy ảnh xuống dưới

        pixmap = QPixmap("hero_bg.png")
        self.bg_label.setPixmap(pixmap)

        # layout nội dung đè lên ảnh
