            }
        """)

        # layout ngoài
        outer = QVBoxLayout(self)
        outer.setContentsMargins(0, 0, 0, 0)
        outer.setSpacing(0)

        # khung chứa ảnh nền
        bg_frame = QFrame()
        bg_frame.setFixedHeight(370)
        bg_frame.setStyleSheet("""
            QFrame {
                border: none;
                border-bottom-left-radius: 12px;
                border-bottom-right-radius: 12px;
            }
        """)

        outer.addWidget(bg_frame)

        # label ảnh nền
