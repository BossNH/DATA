  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #FFF3F9;
    color: #2B2B2B;
    font-family: &quot;Segoe UI&quot;;
}
QFrame#topBar {
    background-color: #EDD5DE;
    border: none;
}
QLabel#brandTitle {
    color: #7B3F73;
    font-size: 21px;
    font-weight: 700;
}
QLabel#brandSub {
    color: #7B7B7B;
    font-size: 11px;
}
QPushButton.navBtn {
    background: transparent;
    border: none;
    color: #222222;
    font-size: 14px;
    font-weight: 600;
    padding: 8px 12px;
    border-radius: 18px;
    text-align: center;
}
QPushButton.navBtn:hover {
    background: rgba(255,255,255,0.35);
}
QPushButton#activeBtn {
    background-color: #E5B6CE;
    color: #1F1F1F;
    font-weight: 700;
}
QLabel#notifDot {
    background-color: #E53935;
    color: white;
    border-radius: 8px;
    font-size: 10px;
    font-weight: 700;
}
QPushButton.iconBtn {
    background: transparent;
    border: none;
    font-size: 20px;
    color: #222222;
}
QLabel#backLabel {
    color: #1E1E1E;
    font-size: 14px;
    font-weight: 600;
}
QLabel#titleLabel {
    color: #76406E;
    font-size: 52px;
    font-weight: 800;
}
QFrame#formCard {
    background-color: #F4DCE6;
    border: none;
    border-radius: 20px;
}
QLabel.formLabel {
    color: #1D1D1D;
    font-size: 17px;
    font-weight: 500;
    background: transparent;
}
QLineEdit.inputBox, QComboBox.inputBox, QTextEdit.inputBox {
    background-color: #FFFFFF;
    border: 1px solid #EDD8E3;
    border-radius: 7px;
    padding: 6px 10px;
    color: #333333;
    font-size: 14px;
}
QLineEdit.inputBox {
    min-height: 30px;
}
QComboBox.inputBox {
    min-height: 30px;
    padding-right: 30px;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 28px;
    border: none;
    background: transparent;
}
QComboBox::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
}
QTextEdit.inputBox {
    padding-top: 8px;
}
QFrame#uploadBox {
    background-color: #FFFFFF;
    border: 1px solid #EDD8E3;
    border-radius: 7px;
}
QLabel#uploadIcon {
    color: #EDBBD0;
    font-size: 62px;
    font-weight: 300;
}
QLabel#uploadText {
    color: #7A3E72;
    font-size: 18px;
    font-weight: 700;
}
QPushButton#doneButton {
    background-color: #EDBDD0;
    border: 1px solid #6E4A60;
    border-radius: 23px;
    color: #6B2E63;
    font-size: 20px;
    font-weight: 800;
    padding: 8px 18px;
}
QPushButton#doneButton:hover {
    background-color: #E8B1C6;
}</string>
