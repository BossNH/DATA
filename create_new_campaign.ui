  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #FFF3F9;
    color: #2B2B2B;
    font-family: "Segoe UI";
}

QScrollArea {
    border: none;
    background: #FFF3F9;
}

QScrollBar:vertical {
    background: #F3DDE7;
    width: 12px;
    border-radius: 6px;
    margin: 6px 2px 6px 2px;
}

QScrollBar::handle:vertical {
    background: #D8A8BE;
    min-height: 40px;
    border-radius: 6px;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
    border: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}

QFrame#topBar {
    background: transparent;
    border: none;
}

QFrame#navFrame {
    background: #F5DCE6;
    border: none;
    border-radius: 18px;
}

QLabel#logoImage {
    background: transparent;
    border: none;
}

QLabel#brandTitle {
    color: #9C4F74;
    font-size: 18pt;
    font-weight: 800;
    background: transparent;
}

QLabel#brandSubtitle {
    color: #9D8A93;
    font-size: 8pt;
    font-weight: 500;
    background: transparent;
}

QPushButton#btnHome,
QPushButton#btnCreate,
QPushButton#btnFollow,
QPushButton#btnPublic {
    background: transparent;
    border: none;
    border-radius: 18px;
    padding: 8px 14px;
    color: #2C2328;
    font-size: 10.5pt;
    font-weight: 600;
    text-align: center;
}

QPushButton#btnHome:hover,
QPushButton#btnCreate:hover,
QPushButton#btnFollow:hover,
QPushButton#btnPublic:hover {
    background: #EEC9D8;
}

QPushButton#btnCreate {
    background: #C98AA5;
    color: white;
    font-weight: 700;
}

QToolButton#btnNotify,
QToolButton#btnSetting,
QToolButton#btnProfile {
    background: transparent;
    border: none;
    border-radius: 15px;
    color: #2C2328;
    font-size: 15pt;
}

QToolButton#btnNotify:hover,
QToolButton#btnSetting:hover,
QToolButton#btnProfile:hover {
    background: #EEC9D8;
}

QLabel#notifyBadge {
    background: #E74C3C;
    color: white;
    border-radius: 8px;
    font-size: 8pt;
    font-weight: 700;
}

QLabel#backLabel {
    color: #1E1E1E;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
}

QLabel#titleLabel {
    color: #76406E;
    font-size: 52px;
    font-weight: 800;
    background: transparent;
}

QFrame#formCard {
    background-color: #F4DCE6;
    border: none;
    border-radius: 20px;
}

QLabel.formLabel {
    color: #1D1D1D;
    font-size: 17px;
    font-weight: 500;
    background: transparent;
}

QLineEdit.inputBox, QComboBox.inputBox, QTextEdit.inputBox {
    background-color: #FFFFFF;
    border: 1px solid #EDD8E3;
    border-radius: 7px;
    padding: 6px 10px;
    color: #333333;
    font-size: 14px;
}

QLineEdit.inputBox {
    min-height: 30px;
}

QComboBox.inputBox {
    min-height: 30px;
    padding-right: 30px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 28px;
    border: none;
    background: transparent;
}

QComboBox::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
}

QTextEdit.inputBox {
    padding-top: 8px;
}

QFrame#uploadBox {
    background-color: #FFFFFF;
    border: 1px solid #EDD8E3;
    border-radius: 7px;
}

QLabel#uploadIcon {
    color: #EDBBD0;
    font-size: 50px;
    font-weight: 300;
    background: transparent;
}

QLabel#uploadText {
    color: #7A3E72;
    font-size: 18px;
    font-weight: 700;
    background: transparent;
}

QPushButton#doneButton {
    background-color: #EDBDD0;
    border: 1px solid #6E4A60;
    border-radius: 23px;
    color: #6B2E63;
    font-size: 20px;
    font-weight: 800;
    padding: 8px 18px;
}

QPushButton#doneButton:hover {
    background-color: #E8B1C6;
}</string>
