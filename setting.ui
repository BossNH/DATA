  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #FFF3F9;
    font-family: &quot;Segoe UI&quot;;
    color: #222222;
}

QLabel {
    background: transparent;
    border: none;
}

QFrame {
    border: none;
    background: transparent;
}

#logoTitle {
    color: #B84588;
    font-size: 26px;
    font-weight: 800;
}

#logoSub {
    color: #8E8E8E;
    font-size: 10px;
    font-weight: 600;
}

#backLabel {
    color: #111111;
    font-size: 18px;
    font-weight: 600;
}

#sectionTitle {
    color: #222222;
    font-size: 32px;
    font-weight: 800;
}

#profileCard {
    background: rgba(255, 243, 249, 180);
    border: 2px solid #F1B6C9;
    border-radius: 24px;
}

#avatarBox {
    background: #D9DDDE;
    border: none;
}

#avatarIcon {
    color: #A9ADB7;
    font-size: 110px;
    font-weight: 700;
}

#cameraIcon {
    color: #1E1E1E;
    font-size: 18px;
    font-weight: 700;
}</string>
