  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background: #F7EEF2;
    font-family: &quot;Segoe UI&quot;;
    color: #2F2A2E;
}

QFrame#topBar {
    background: #F2D6DF;
    border: none;
}

QLabel#brandLabel {
    color: #8B3D73;
    font-size: 16pt;
    font-weight: 800;
    background: transparent;
}

QLabel#subBrandLabel {
    color: #8B3D73;
    font-size: 7pt;
    background: transparent;
}

QPushButton#navHome {
    background: #E6B7CA;
    border: none;
    border-radius: 18px;
    padding: 8px 16px;
    font-size: 10pt;
    font-weight: 700;
    color: #2F2A2E;
}

QPushButton#navStats,
QPushButton#navChatbot,
QPushButton#navPublic {
    background: transparent;
    border: none;
    padding: 8px 10px;
    font-size: 10pt;
    font-weight: 700;
    color: #2F2A2E;
}

QPushButton#navHome:hover,
QPushButton#navStats:hover,
QPushButton#navChatbot:hover,
QPushButton#navPublic:hover {
    color: #7A2F62;
}

QPushButton#btnNotify,
QPushButton#btnSetting,
QPushButton#btnUser {
    background: transparent;
    border: none;
    font-size: 16pt;
    color: #2F2A2E;
}

QFrame#heroFrame {
    background: #E9DADF;
    border: none;
}

QLabel#heroImage {
    border: none;
    background: transparent;
}

QLabel#heroTitle {
    background: transparent;
    color: #111111;
    font-size: 44pt;
    font-weight: 900;
}

QLabel#heroSubtitle {
    background: transparent;
    color: #1C1C1C;
    font-size: 18pt;
    font-weight: 700;
}

QWidget#categoryArea {
    background: #F7EEF2;
}

QFrame#cat1, QFrame#cat2, QFrame#cat3, QFrame#cat4, QFrame#cat5, QFrame#cat6 {
    background: transparent;
    border: none;
}

QLabel#icon1, QLabel#icon2, QLabel#icon3, QLabel#icon4, QLabel#icon5, QLabel#icon6 {
    color: #8B3D73;
    font-size: 27pt;
    font-weight: 700;
    qproperty-alignment: AlignCenter;
}

QLabel#text1, QLabel#text2, QLabel#text3, QLabel#text4, QLabel#text5, QLabel#text6 {
    color: #8B3D73;
    font-size: 10pt;
    font-weight: 600;
    qproperty-alignment: AlignCenter;
    background: transparent;
}

QFrame#bottomBar {
