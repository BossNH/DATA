  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget{
background:#FFF3F9;
font-family:"Segoe UI";
}

QFrame#topBar{
background:#F4D8E3;
border:none;
}

QLabel#logoText{
font-size:18px;
font-weight:700;
color:#7A4E6A;
}

QLabel#menu1, QLabel#menu2, QLabel#menu3, QLabel#menu4{
font-size:14px;
font-weight:600;
color:#2F2A2E;
padding:6px 10px;
}

QLabel#menu2{
background:#E8BFD0;
border-radius:14px;
padding:8px 14px;
}

QLabel#bellIcon, QLabel#userIcon{
font-size:20px;
color:#2F2A2E;
}

QLabel#titleLabel{
font-size:32px;
font-weight:700;
color:#6C4A63;
background:transparent;
}

QLabel#descLabel{
font-size:16px;
color:#444444;
background:transparent;
}

QFrame#contentFrame{
background:#FFFFFF;
border:none;
border-radius:20px;
}

QPushButton#backButton{
background:transparent;
border:none;
font-size:14px;
font-weight:600;
color:#333333;
text-align:left;
padding-left:6px;
}

QPushButton#backButton:hover{
color:#6C4A63;
}</string>
